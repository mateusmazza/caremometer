rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Participant documents — keyed by pid (e.g. "P001")
    // Anyone who knows the pid can read/write their own document.
    // This is acceptable for this study: pids are researcher-controlled
    // and distributed directly to participants via personal links.
    // The researcher dashboard is protected by Firebase Auth on the client.
    //
    // For a higher-security deployment, tighten to:
    //   allow write: if request.auth == null && request.resource.data.id == pid;
    //   allow read, write: if request.auth != null;
    match /participants/{pid} {
      allow read, write: if true;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
