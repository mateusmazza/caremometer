er para sentirme mejor."},"3":{"Display":"Cuando estoy molesto\/a, mis emociones se sienten abrumadoras."}},"Answers":{"1":{"Display":"Casi nunca<br \/>\n(0-10%)"},"6":{"Display":"A veces<br \/>\n(11-35%)"},"7":{"Display":"Aproximadamente la mitad del tiempo<br \/>\n(36-65%)"},"8":{"Display":"La mayor parte del tiempo<br \/>\n(66-90%)"},"9":{"Display":"Casi siempre<br \/>\n(91-100%)"}}}},"NextChoiceId":4,"NextAnswerId":11,"Answers":{"1":{"Display":"Almost never<br \/>\n(0-10%)"},"6":{"Display":"Sometimes<br \/>\n(11-35%)"},"7":{"Display":"About half the time<br \/>\n(36-65%)"},"8":{"Display":"Most of the time<br \/>\n(66-90%)"},"9":{"Display":"Almost always<br \/>\n(91-100%)"}},"AnswerOrder":["1","6","7","8","9"],"ChoiceDataExportTags":false}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID390","SecondaryAttribute":"What best describes your gender identity?","TertiaryAttribute":null,"Payload":{"QuestionText":"What best describes your gender identity?<br><br>","DataExportTag":"pgender","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What best describes your gender identity?","Choices":{"1":{"Display":"Woman"},"2":{"Display":"Man"},"3":{"Display":"Non-Binary"},"4":{"Display":"Other (Specify)","TextEntry":"true"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID390"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID391","SecondaryAttribute":"Child Name:","TertiaryAttribute":null,"Payload":{"QuestionText":"Child Name:","DefaultChoices":false,"DataExportTag":"cname","QuestionType":"TE","Selector":"FORM","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":