<span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID309\/SelectableChoice\/2","LogicType":"Question","Operator":"Selected","QuestionID":"QID309","QuestionIDFromLocator":"QID309","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID396","SecondaryAttribute":"In which country was your partner born?","TertiaryAttribute":null,"Payload":{"QuestionText":"In which country was your partner born?","DefaultChoices":false,"DataExportTag":"partner_country","QuestionID":"QID396","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In which country was your partner born?","Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"DisplayLogic":{"0":{"0":{"LogicType":"Question","QuestionID":"QID314","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID314\/SelectableChoice\/2","Operator":"Selected","QuestionIDFromLocator":"QID314","LeftOperand":"q:\/\/QID314\/SelectableChoice\/2","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Was your partner born in the U.S.?<\/span> <span class=\"LeftOpDesc\">No<\/span> <span class=\"OpDesc\">Is Selected<\/span> "},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID397","SecondaryAttribute":"Is your partner involved in parenting your child with you?","TertiaryAttribute":null,"Payload":{"QuestionText":"Is your partner involved in parenting your child with you?","DataExportTag":"partnerparent","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Is your partner involved in parenting your child with you?","Choices":{"1":{"Display":"Yes, we co-parent"},"2":{"Display":"Yes, but I consider myself a single parent"},"3":{"Display":"No"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID397"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID398","SecondaryAttribute":"What language(s) do you speak fluently? (Please check all that apply).","TertiaryAttribute":null,"Payload":{"QuestionText":"What language(s) do you speak fluently? (Please check all that apply).","DataExportTag":"plang","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What language(s) do you speak fluently? (Please check all that apply).","Choices":{"1":{"Display":"English"},"2":{"Display":"Spanish"},"3":{"Display":"Chinese"},"4":{"Display":"Not listed (please specify)","TextEntry":"true"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID398"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID399","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q218","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID399"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID400","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q219","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID400"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID401","SecondaryAttribute":"Study Title: Child Development and Learning in the Family Context Protocol Director: This study i...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:16px;\"><u>Study Title: <\/u>Child Development and Learning in the Family Context<br>\n<br>\n<u>Protocol Director:<\/u> This study is being conducted by Dr. Jelena Obradovi\u0107, a developmental psychologist and professor in the Graduate School of Education at Stanford University.<br>\n<br>\nDear Parent\/Guardian, I am inviting you and your child (age 5-12) to participate in education research about day-to-day changes in children's learning-related skills. Specifically, this research focuses on how children's mood and daily experiences relate to short-term changes in their executive functions. We believe this work has important implications for how we understand children\u2019s readiness to learn. If you agree:<\/span>\n<ul>\n\t<li><span style=\"font-size:16px;\">You and your child will participate in a 45-minute zoom session with a research assistant. During this session, you and your child will answer surveys about your family background, your child\u2019s experiences and behavior, your personal experiences, and your parenting behaviors. On your smartphone or iPad, we will help you install an app with games that will measure your child\u2019s executive functions. Your child will play the games during the session. We will also explain the daily activities you will do at home for the next part of the study. The audio and video from this meeting will be recorded and stored securely. <\/span><\/li>\n\t<li><span style=\"font-size:16px;\">During the two weeks following the call, you and your child will participate in short daily activities for up to 8 days. Each day, you will receive a message reminding you to (1) complete a brief, one-minute survey, (2) have your child complete a brief, one-minute survey, and (3) have your child play two short smartphone or iPad games for 10 minutes. <\/span><\/li>\n<\/ul>\n<br>\n<span style=\"font-size:16px;\"><strong>Time Required<\/strong>: You and your child will participate in one, 45-minute session. You will complete daily surveys for up to 8 minutes total (1 minute\/day). Your child will play games and complete surveys for up to 1 hour and 28 minutes total (11 minutes\/day).<br>\n<br>\n<strong>Payment:<\/strong> To show our gratitude for your time, we will send you a $25 gift card for participating in the initial zoom session. You will receive $5 per day for each day you and your child complete your daily surveys and your child plays games, for up to 8 days. If you complete at least 6 days, you\u2019ll receive a $10 bonus in addition to daily payments.<br>\n<br>\n<strong>Risks:<\/strong> The risks associated with this study are minimal. Study data will be stored securely, in compliance with Stanford University standards, minimizing the risk of confidentiality breach.<br>\n<br>\n<strong>Benefits:<\/strong> We cannot and do not guarantee you will receive any benefits in this study. Society will benefit because of the enhanced understanding of children's day-to-day fluctuations in learning-related skills. In the long term, this research has the potential to inform educational practices, policies, and intervention that support children's readiness to learn.<br>\n<br>\n<strong>Participants\u2019 Rights: <\/strong>If you have read this form and have decided to participate in this project, please under-stand your participation is voluntary and you have the right to withdraw your consent or discontinue participation at any time without penalty or loss of benefits to which you are otherwise entitled. The alternative is not to participate. You have the right to refuse to answer particular questions. The results of this research study may be presented at scientific or professional meetings or published in scientific journals. Your individual privacy will be maintained in all published and written data resulting from the study.<br>\n<br>\n<strong>Confidentiality:<\/strong> Data for individual participants is confidential and will not be shared outside of the research team. In any report about the study, there will be no information to identify you and your individual privacy will be protected. Identifiers might be removed from identifiable private information, and, after such removal, the information could be used for future research studies or distributed to another investigator for future research studies without additional informed consent from you.<br>\n<br>\n<strong>Contact Information:<\/strong><br>\n<br>\n<u>Questions<\/u>: If you have any questions, concerns or complaints about this research, its procedures, risks and benefits, you are encouraged to contact the Protocol Director, Dr. Jelena Obradovi\u0107 by phone: (650) 725-1250 or email: jelena.obradovic@stanford.edu.<br>\n<br>\n<u>Independent Contact<\/u>: If you are not satisfied with how this study is being conducted, or if you have any concerns, complaints, or general questions about the research or your rights as a participant, please contact the Stanford Institutional Review Board (IRB) to speak to someone independent of the research team at (650) 723-2480 or toll free at 1-866-680-2906. You can also email irbnonmed@stanford.edu or write Stanford IRB, Stanford University, MC 5579, Palo Alto, CA 94304.<br>\n<br>\nStanford IRB approval date: 8\/19\/2025<br>\nExpiration date: (Does not expire) <\/span>","DefaultChoices":false,"DataExportTag":"Consent","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Study Title: Child Development and Learning in the Family Context Protocol Director: This study i...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID401"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID402","SecondaryAttribute":"Do we have permission to contact you about opportunities to participate in future research? Your...","TertiaryAttribute":null,"Payload":{"QuestionText":"Do we have permission to contact you about opportunities to participate in future research?\nYour contact information will not be shared outside the research team and will only be used to tell you about future research opportunities. Information from the current study will be used to determine whether you are eligible to participate in future research.","DefaultChoices":false,"DataExportTag":"future_contact","QuestionID":"QID402","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do we have permission to contact you about opportunities to participate in future research? Your...","Choices":{"1":{"Display":"<strong>YES<\/strong>, I give permission to contact me about future research opportunities."},"2":{"Display":"<strong>NO<\/strong>, I do NOT give permission to contact me about opportunities to participate in future research."}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID403","SecondaryAttribute":"Please provide your contact information to be informed about future studies:","TertiaryAttribute":null,"Payload":{"QuestionText":"Please provide your contact information to be informed about future studies:","DefaultChoices":false,"DataExportTag":"contact_info","QuestionType":"TE","Selector":"FORM","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please provide your contact information to be informed about future studies:","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID403","Choices":{"1":{"Display":"*Your first name:"},"2":{"Display":"*Your last name:"},"3":{"Display":"Email address:"},"4":{"Display":"*Phone number:"}},"ChoiceOrder":["1","2","3","4"],"DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID402\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Do we have permission to contact you about opportunities to participate in future research?\nYour contact information will not be shared outside the research team and will only be used to tell you a...<\/span> <span class=\"LeftOpDesc\">&lt;strong&gt;YES&lt;\/strong&gt;, I give permission to contact me about future research opportunities.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID402\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID402","QuestionIDFromLocator":"QID402","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID404","SecondaryAttribute":"I have read the above information. I give consent for me and my child to participate in the resea...","TertiaryAttribute":null,"Payload":{"QuestionText":"I have read the above information. I give consent for me and my child to participate in the research study described above.","DefaultChoices":false,"DataExportTag":"consent_info","QuestionID":"QID404","QuestionType":"TE","Selector":"FORM","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I have read the above information. I give consent for me and my child to participate in the resea...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"Choices":{"1":{"Display":"*Child's First Name"},"2":{"Display":"*Child's Last Name"},"4":{"Display":"*Your First Name"},"5":{"Display":"*Date","InputHeight":28,"InputWidth":300,"TextEntry":"on"},"6":{"Display":"Your Last Name"}},"ChoiceOrder":["1","2","4","6","5"]}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID405","SecondaryAttribute":"Signature:","TertiaryAttribute":null,"Payload":{"QuestionText":"Signature:","DefaultChoices":false,"DataExportTag":"consent_signature","QuestionID":"QID405","QuestionType":"Draw","Selector":"Signature","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","ShowBackgroundText":true,"BoxSize":"Medium"},"QuestionDescription":"Signature:","Validation":{"Settings":{"ForceResponse":"ON"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID406","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q225","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID406"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID407","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q226","QuestionType":"RO","Selector":"DND","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Item 1"},"2":{"Display":"Click to write Item 2"},"3":{"Display":"Click to write Item 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID407"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID408","SecondaryAttribute":"On a typical day when your child has chores to do (e.g., pick up clothes\/toys, make their bed, he...","TertiaryAttribute":null,"Payload":{"QuestionText":"On a typical day when your child has chores to do (e.g., pick up clothes\/toys, make their bed, help with dishes), how independently does your child complete their chores?","DefaultChoices":false,"DataExportTag":"chores_independence","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"On a typical day when your child has chores to do (e.g., pick up clothes\/toys, make their bed, he...","Choices":{"1":{"Display":"On their own (They complete their chores regularly without being asked or reminded)"},"2":{"Display":"With a reminder (They typically need one verbal reminder or they rely on a visual chart or list)"},"3":{"Display":"With many reminders (They require repeated asking to complete their chores)"},"4":{"Display":"With a few reminders (They typically need more than one reminder to complete their chores)"},"5":{"Display":"Does not apply (My child is not expected to do chores)"}},"ChoiceOrder":["1","2","4","3","5"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID408"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID409","SecondaryAttribute":"How well do these statements describe your child?","TertiaryAttribute":null,"Payload":{"QuestionText":"How well do these statements describe your child?","DefaultChoices":false,"DataExportTag":"Q228","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"How well do these statements describe your child?","Choices":{"1":{"Display":"When faced with a difficult task, my child finds something else to do instead"},"2":{"Display":"My child actively tries to solve even the most difficult tasks."},"3":{"Display":"My child easily gives up on the task at hand."},"4":{"Display":"My child shows persistence when working on a task."},"5":{"Display":"When