D365"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID366","SecondaryAttribute":"Finally, please answer the following questions about your own experiences and feelings. Think abo...","TertiaryAttribute":null,"Payload":{"QuestionText":"Finally, please answer the following questions about your own experiences and feelings. Think about all of the things you have to do in a typical week and select the response that best fits you.","DefaultChoices":false,"DataExportTag":"caregiver_overload","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Finally, please answer the following questions about your own experiences and feelings. Think abo...","Choices":{"1":{"Display":"How often do you feel pulled apart from having to juggle conflicting obligations?"},"2":{"Display":"How often do you have plenty of time to rest, relax, or do things you enjoy?"},"3":{"Display":"How often do the things you do add up to being just too much?"},"4":{"Display":"How often do you feel tied down by all your commitments?"},"5":{"Display":"How often do you feel free to do the things you want to do?"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Never"},"2":{"Display":"Rarely"},"3":{"Display":"Sometimes"},"4":{"Display":"Often"},"5":{"Display":"Almost Always"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID366"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID367","SecondaryAttribute":"This section includes descriptions of family routines and traditions. Every family is somewhat di...","TertiaryAttribute":null,"Payload":{"QuestionText":"This section includes descriptions of family routines and traditions. Every family is somewhat different in the types of routines and traditions that they follow. In some families, routines and traditions are very important but in other families there is a more casual attitude toward routines and traditions. \n\nThink of how your family typically acts during the following events. Read the statements and choose the response that best describes your current family.\n\nHow true are these statements about your family?","DefaultChoices":false,"DataExportTag":"Label","QuestionID":"QID367","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This section includes descriptions of family routines and traditions. Every family is somewhat di...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID368","SecondaryAttribute":"Think about a typical dinner in your home with your family.","TertiaryAttribute":null,"Payload":{"QuestionText":"Think about a<strong> typical dinner<\/strong> in your home with your family.","DefaultChoices":false,"DataExportTag":"dinner_routine","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Think about a typical dinner in your home with your family.","Choices":{"1":{"Display":"In our family, dinner time is planned in advance."},"2":{"Display":"Our family regularly eats dinner together."},"3":{"Display":"In our family, we feel it is important that we eat together."},"4":{"Display":"In our family, everyone is expected to be home for dinner."},"5":{"Display":"In our family at dinner time, everyone has a specific role or job to do."},"6":{"Display":"In our family, dinner time is flexible; people eat whenever they want."}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":5,"Answers":{"1":{"Display":"Not at all true"},"2":{"Display":"Sort of true"},"3":{"Display":"Very true"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false,"QuestionID":"QID368"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID369","SecondaryAttribute":"Think about a typical weekend in your family.","TertiaryAttribute":null,"Payload":{"QuestionText":"Think about a<strong> typical weekend <\/strong>in your family.","DefaultChoices":false,"DataExportTag":"weekend_routine","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":195},"QuestionDescription":"Think about a typical weekend in your family.","Choices":{"1":{"Display":"In our family, we feel that it is important to spend time together on the weekends."},"2":{"Display":"Our family rarely spends weekends together."},"3":{"Display":"In our family, people pretty much come and go as they please on the weekends."},"4":{"Display":"In our family, there are no assigned jobs to be done on the weekends."},"5":{"Display":"In our family, there is much discussion and planning for the weekend."},"6":{"Display":"In our family, we have set routines and regular events that we all participate in on the weekends."}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceRespon