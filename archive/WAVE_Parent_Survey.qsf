n't go to their friend's birthday party, I would:","DefaultChoices":false,"DataExportTag":"scenario1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If your child becomes angry because they are sick and can't go to their friend's birthday party,...","Choices":{"1":{"Display":"Send them away to cool off"},"2":{"Display":"Get angry at them"},"3":{"Display":"Help them think about ways that they can still be with friends (e.g., invite friends over another time)"},"4":{"Display":"Tell them not to make a big deal out of missing the party"},"5":{"Display":"Encourage them to express their feelings of anger and frustration"},"6":{"Display":"Comfort them and do something fun to make them feel better about missing the party"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID327"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID328","SecondaryAttribute":"If your child is doing a group activity with their friends and gets embarrassed and upset after m...","TertiaryAttribute":null,"Payload":{"QuestionText":"If your child is doing a group activity with their friends and gets embarrassed and upset after making a mistake, I would:","DataExportTag":"scenario2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If your child is doing a group activity with their friends and gets embarrassed and upset after m...","Choices":{"1":{"Display":"Comfort them and try to make them feel better"},"2":{"Display":"Tell them that they are over-reacting"},"3":{"Display":"Feel uncomfortable and embarrassed myself"},"4":{"Display":"Tell them to calm down or we'll go home right away"},"5":{"Display":"Encourage them to talk about their feelings of embarrassment"},"6":{"Display":"Tell them that I'll help them practice so that they can do better next time"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID328"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID329","SecondaryAttribute":"If your child becomes visibly nervous about presenting or performing (e.g., a recital or sports e...","TertiaryAttribute":null,"Payload":{"QuestionText":"If your child becomes visibly nervous about presenting or performing (e.g., a recital or sports event) with people watching them, I would:","DefaultChoices":false,"DataExportTag":"scenario3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If your child becomes visibly nervous about presenting or performing (e.g., a recital or sports e...","Choices":{"1":{"Display":"Help them think of things that they could do to get ready (e.g., to do some warm-ups)"},"2":{"Display":"Suggest that they think about something relaxing to calm down"},"3":{"Display":"Get nervous myself"},"4":{"Display":"Tell them that they are being a baby about it"},"5":{"Display":"Tell them that if they don't calm down, we'll have to leave and go home right away"},"6":{"Display":"Encourage them to talk about their nervous feelings"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID329"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"My child would rather","TertiaryAttribute":null,"Payload":{"QuestionText":"My child would rather","DefaultChoices":false,"DataExportTag":"c1cp6","Quest