ceId":8,"NextAnswerId":6,"Answers":{"1":{"Display":"Never"},"2":{"Display":"Rarely"},"3":{"Display":"Sometimes"},"4":{"Display":"Often"},"5":{"Display":"Almost Always"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID334"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID335","SecondaryAttribute":"If your child receives an undesirable birthday gift from a friend and looks obviously disappointe...","TertiaryAttribute":null,"Payload":{"QuestionText":"If your child receives an undesirable birthday gift from a friend and looks obviously disappointed or annoyed after opening it in front of their friend, I would:","DefaultChoices":false,"DataExportTag":"ccnes_scenario4","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"If your child receives an undesirable birthday gift from a friend and looks obviously disappointe...","Choices":{"1":{"Display":"Encourage them to express their disappointed feelings privately"},"8":{"Display":"Tell them privately that the present can be exchanged for something they want"},"9":{"Display":"Be annoyed with them for being rude"},"10":{"Display":"Tell them that they are over-reacting"},"11":{"Display":"Scold them for being insensitive to the friend's feelings"},"12":{"Display":"Try to get them to feel better by doing something fun"}},"ChoiceOrder":["1","8","9","10","11","12"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":14,"NextAnswerId":6,"Answers":{"1":{"Display":"Never"},"2":{"Display":"Rarely"},"3":{"Display":"Sometimes"},"4":{"Display":"Often"},"5":{"Display":"Almost Always"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID335"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID336","SecondaryAttribute":"If your child looks hurt and upset because another child called them names, I would:","TertiaryAttribute":null,"Payload":{"QuestionText":"If your child looks hurt and upset because another child called them names, I would:","DefaultChoices":false,"DataExportTag":"ccnes_scenario5","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"If your child looks hurt and upset because another child called them names, I would:","Choices":{"1":{"Display":"Tell them not to make a big deal out of it"},"14":{"Display":"Feel upset myself"},"15":{"Display":"Tell them to behave or we'll have to go home right away"},"16":{"Display":"Help them think of constructive things to do when other children tease them (e.g., find other things to do)"},"17":{"Display":"Comfort them and play a game to take their mind off the upsetting event"},"18":{"Display":"Encourage them to talk about how it hurts to be teased"}},"ChoiceOrder":["1","14","15","16","17","18"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":6,"Answers":{"1":{"Display":"Never"},"2":{"Display":"Rarely"},"3":{"Display":"Sometimes"},"4":{"Display":"Often"},"5":{"Display":"Almost Always"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID336"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID337","SecondaryAttribute":"The following questions are about activities you do with your child. How often do you\u2026","TertiaryAttribute":null,"Payload":{"QuestionText":"The following questions are about activities you do with your child. \r\nHow often do you\u2026","DefaultChoices":false,"DataExportTag":"activity_freq","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":182},"QuestionDescription":"The following questions are about activities you do with your child. How often do you\u2026","Choices":{"2":{"Display":"Sing, dance, play music, or listen to music with your child"},"4":{"Display":"Help your child with their schoolwork"},"5":{"Display":"Play games or do puzzles with your child"},"6":{"Display":"Talk about nature or do science with your child"},"7":{"Display":"Help your child build, craft, make, or fix something"},"8":{"Display":"Play a sport or exercise together with your child"},"9":{"Display":"Go outings together with your child (e.g., park, playground, museum, performance)"},"10":{"Display":"Read with your child"}},"ChoiceOrder":["9","2","4","5","6","7","8","10"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":12,"NextAnswerId":7,"Answers":{"1":{"Display":"Never or rarely"},"2":{"Display":"A few times a year"},"3":{"Display":"Once or twice a month"},"4":{"Display":"About once a week"},"5":{"Display":"A few times a week"},"6":{"Display":"Almost every day"}},"AnswerOrder":["1","2","3","4","5","6"],"ChoiceDataExportTags":false,"QuestionID":"QID337"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID338","SecondaryAttribute":"The following questions are about your approach to discipline with your child. Please indicate ho...","TertiaryAttribute":null,"Payload":{"QuestionText":"The following questions are about your approach to discipline with your child. Please indicate how often the following statements apply when you discipline your child.","DefaultChoices":false,"DataExportTag":"discipine","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":178},"QuestionDescription":"The following questions are about your approach to discipline with your child. Please indicate ho...","Choices":{"1":{"Display":"You threaten to discipline your child and then do not actually discipline them"},"2":{"Display":"Your child talks you out of negative consequences after they have done something wrong"},"3":{"Display":"You give up trying to get your child to obey because it's too much trouble"},"4":{"Display":"You let your child out of negative consequences early (like lift restrictions earlier than you originally said)"},"5":{"Display":"Your child is not disciplined when they have done something wrong"},"6":{"Display":"How you discipline your child depends on your mood"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":6,"Answers":{"1":{"Display":"Never"},"2":{"Display":"Rarely"},"3":{"Display":"Sometimes"},"4":{"Display":"Often"},"5":{"Display":"Always"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID338"}},{"SurveyID":"SV_0OCvVTAwj66A9ts","Element":"SQ","PrimaryAttribute":"QID339","SecondaryAttribute":"We\u2019d like to learn more about the different experiences families may have and how they might shap.","TertiaryAttribute":null,"Payload":{"QuestionText":"We\u2019d like to learn more about the different experiences families may have and how they might shape children\u2019s behavior and routines. Your responses help us understand the everyday realities that influence family life. During your child\u2019s lifetime\u2026","DefaultChoices":false,"DataExportTag":"instability_ratings","QuestionID":"QID339","QuestionType":"SBS","Selector":"SBSMatrix","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","RepeatHeaders":"none","ChoiceColumnWidthPixels":338},"QuestionDescription":"We\u2019d like to learn more about the different experiences families may have and how they might shap...","Choices":{"1":{"Display":"How many times has your child moved to another residence?"},"2":{"Display":"How many times has your child changed primary caregivers?"},"3":{"Display":"How many times has your child changed secondary caregivers? For example, preschool teachers, family members, or anyone else who regularly cares for the child, but who isn\u2019t a primary caregiver?"},"4":{"Display":"Since your child was born, how many different people (including yourself and your child) have lived in your household, even if they no longer live there?"},"5":{"Display":"Since your child was born, how many times has someone joined or left your household? For example, another baby was born, or a spouse\/partner moved in or left. Please count each transition as a separate event."},"6":{"Display":"How many different care or education programs (e.g., family care, daycare, preschool, TK, elementary school) has your child attended?"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":2,"NumberOfQuestions":1,"AdditionalQuestions":{"1":{"Answers":{"1":{"Display":"Count"}},"QuestionText":"Number (e.g. 0, 1, 2, 3)","RecodeValues":[],"VariableNaming":[],"AnalyzeChoices":[],"QuestionType":"Matrix","Selector":"TE","SubSelector":"