[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID6"}},{"SurveyID":"SV_6YGlbRXAmvSL8we","Element":"SQ","PrimaryAttribute":"QID7","SecondaryAttribute":"Em que medida voc\u00ea concorda com as seguintes afirma\u00e7\u00f5es?","TertiaryAttribute":null,"Payload":{"QuestionText":"Em que medida voc\u00ea concorda com as seguintes afirma\u00e7\u00f5es?","DefaultChoices":false,"DataExportTag":"Q7","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Em que medida voc\u00ea concorda com as seguintes afirma\u00e7\u00f5es?","Choices":{"1":{"Display":"Estou disposta(o) a me esfor\u00e7ar em um curso para aprender o conte\u00fado, mesmo que isso n\u00e3o leve a uma nota mais alta."},"2":{"Display":"Quando me saio bem em uma prova, geralmente \u00e9 porque estou bem preparada(o), e n\u00e3o porque a prova \u00e9 f\u00e1cil."},"3":{"Display":"Frequentemente leio mais do que o exigido em uma disciplina, simplesmente porque o assunto me interessa."},"4":{"Display":"Frequentemente converso com professores fora da aula sobre ideias discutidas em sala."},"5":{"Display":"Tirar as melhores notas poss\u00edveis \u00e9 muito importante para mim."},"6":{"Display":"Gosto do desafio de aprender conte\u00fados novos e complexos."},"7":{"Display":"Minhas experi\u00eancias acad\u00eamicas (como aulas, estudos, conversas com professores) s\u00e3o a parte mais importante dos meus dias."},"8":{"Display":"Minhas experi\u00eancias acad\u00eamicas (como aulas, laborat\u00f3rios, estudos, conversas com professores) s\u00e3o as partes mais prazerosas dos meus dias."}},"ChoiceOrder":[1,2,3,4,5,6,7,8],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type