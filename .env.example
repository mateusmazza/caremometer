# Firebase configuration — create a free project at https://console.firebase.google.com
# Copy this file to .env.local and fill in your values.
# See FIREBASE_SETUP.md for step-by-step instructions.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Researcher password for the admin dashboard (change this!)
VITE_RESEARCHER_PASSWORD=precarity-research-2025
